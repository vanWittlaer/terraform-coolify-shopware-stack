# Copy to `secrets.auto.tfvars` (git-ignored) and fill in real values.
# `*.auto.tfvars` is loaded automatically by tofu — no -var-file needed. Keep this file OUT of
# git; only this `.example` is committed.
#
# coolify_endpoint / coolify_token may also be supplied via the COOLIFY_ENDPOINT /
# COOLIFY_TOKEN env vars instead of setting them here.
# coolify_endpoint = "https://coolify.example.com"
# coolify_token    = "REPLACE_ME"   # effectively root — guard it

# Per-env Coolify SERVER lives inside each secrets_* object (server_uuid): same UUID both =
# co-located prod+staging; different = split across servers. One Coolify instance manages both.
#
# The three values you OWN (Coolify can't generate them): app_secret / instance_id /
# rabbitmq_password. Generate with `openssl rand -hex 16`; DISTINCT per env; keep app_secret /
# instance_id STABLE across deploys. DB/Redis passwords stay Coolify-generated.

secrets_production = {
  server_uuid                 = "REPLACE_ME"
  app_secret                  = "REPLACE_ME"
  instance_id                 = "REPLACE_ME"
  rabbitmq_password           = "REPLACE_ME"
  s3_access_key_id            = "REPLACE_ME"
  s3_secret_access_key        = "REPLACE_ME"
  s3_backup_access_key_id     = "REPLACE_ME" # required when enable_backup = true
  s3_backup_secret_access_key = "REPLACE_ME"
  mailer_dsn                  = "null://null" # optional; real SMTP DSN for production mail
  # redis_url_seed: LEAVE UNSET on a fresh install — the module captures the real Redis URLs at
  # create time. Only needed to REPAIR a pre-existing deployment whose Redis internal_db_url was
  # already nulled in state (the provider doesn't round-trip it). Paste the URLs from the Coolify
  # UI (Databases -> redis-cache / redis-session -> connection string), keyed cache/session:
  # redis_url_seed = {
  #   cache   = "redis://default:<pw>@<redis-cache-db-uuid>:6379/0"
  #   session = "redis://default:<pw>@<redis-session-db-uuid>:6379/0"
  # }
}

secrets_staging = {
  server_uuid                 = "REPLACE_ME"
  app_secret                  = "REPLACE_ME"
  instance_id                 = "REPLACE_ME"
  rabbitmq_password           = "REPLACE_ME"
  s3_access_key_id            = "REPLACE_ME"
  s3_secret_access_key        = "REPLACE_ME"
  s3_backup_access_key_id     = "REPLACE_ME"
  s3_backup_secret_access_key = "REPLACE_ME"
  # Mailpit web-UI basic auth (MP_UI_AUTH) when enable_mailpit = true. Space-separated
  # "user:password" pair(s). Empty/omitted => Mailpit UI is open.
  mailpit_ui_auth = "REPLACE_ME"
  # redis_url_seed = { cache = "...", session = "..." }   # migration-only, see production note above
}
